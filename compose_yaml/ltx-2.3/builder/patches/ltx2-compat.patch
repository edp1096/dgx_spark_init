+    def _load_fast(self, model_paths: list[str], sd_ops: SDOps, device: torch.device) -> StateDict:
+        """Load using fastsafetensors — bypasses mmap for much faster loading on unified memory."""
+        sd = {}
+        size = 0
+        dtype = set()
+        # fastsafetensors requires device index (e.g. "cuda:0", not "cuda")
+        device_str = str(device)
+        if device_str == "cuda":
+            device_str = "cuda:0"
+        for shard_path in model_paths:
+            with fastsafetensors.fastsafe_open(shard_path, framework="pt", device=device_str, nogds=True) as f:
+                for name in f.keys():
+                    expected_name = name if sd_ops is None else sd_ops.apply_to_key(name)
+                    if expected_name is None:
+                        continue
+                    # .clone() ensures tensors own their memory (not views into shared buffer)
+                    value = f.get_tensor(name).clone()
+                    key_value_pairs = ((expected_name, value),)
+                    if sd_ops is not None:
+                        key_value_pairs = sd_ops.apply_to_key_value(expected_name, value)
+                    for key, value in key_value_pairs:
+                        size += value.nbytes
+                        dtype.add(value.dtype)
+                        sd[key] = value
+        return StateDict(sd=sd, device=device, size=size, dtype=dtype)
+
 
